# colab_bridge/.env — auto-injected into every Colab job as os.environ keys.
# Copy this file to `colab_bridge/.env` (relative to the installed package)
# and fill in the values for whichever secrets you actually use.
#
# Set / view from the CLI instead of editing by hand:
#   colab --env-set HF_TOKEN                       # interactive (hidden input)
#   colab --env-set HF_TOKEN=hf_xxx                # direct
#   colab --env-set gcs_creds --from-file key.json # multi-line / JSON
#   colab --env                                    # list KEY names (values hidden)
#   colab --env-show HF_TOKEN                      # print one value
#   colab --env-rm  HF_TOKEN
#
# File permissions: the CLI keeps `.env` at mode 0600 on disk. It is gitignored.
# Values are sent over TLS to Colab inside the `execute_request` prelude; Colab's
# own server-side logging is out of our control.

# Hugging Face — used by `huggingface_hub`, `transformers`, `datasets`.
HF_TOKEN=

# OpenAI / OpenAI-compatible APIs.
OPENAI_API_KEY=

# GitHub personal access token (e.g. for `pip install git+https://...`).
GITHUB_TOKEN=

# Google Cloud service-account JSON for `colab_bridge.gcs_agent.GCSAgent`.
# Paste the entire JSON content (one line or multi-line both work):
# gcs_creds='{"type":"service_account","project_id":"...", ...}'
gcs_creds=
